    {
        "text": "praṇipatyārhataḥ siddhasāṅgaśabdānuśāsanaḥ / (1.1) Par.?"
    },
    {
        "text": "rūḍhayaugikamiśrāṇāṃ nāmnāṃ mālāṃ tanomyaham // (1.2) Par.?"
    },
    {
        "text": "vyutpattirahitāḥ śabdā rūḍhā ākhaṇḍalādayaḥ / (2.1) Par.?"
    },
    {
        "text": "yogo 'nvayaḥ sa tu guṇakriyāsaṃbandhasaṃbhavaḥ // (2.2) Par.?"
    },
    {
        "text": "guṇato nīlakaṇṭhādyāḥ kriyātaḥ sraṣṭṛsaṃnibhāḥ / (3.1) Par.?"
    },
    {
        "text": "svasvāmitvādisaṃbandhastatrāhurnāma tadvatām // (3.2) Par.?"
    },
    {
        "text": "svāt pāladhanabhugnetṛpatimatvarthakādayaḥ / (4.1) Par.?"
    },
    {
        "text": "bhūpālo bhūdhano bhūbhugbhūnetā bhūpatistathā // (4.2) Par.?"
    },
    {
        "text": "bhūmāṃśceti kavirūḍhyā jñeyodāharaṇāvalī / (5.1) Par.?"
    },
    {
        "text": "janyāt kṛtkartṛsṛṭsraṣṭṛvidhātṛkarasūsamāḥ // (5.2) Par.?"
    },
    {
        "text": "janakād yonijaruhajanmabhūsūtyaṇādayaḥ / (6.1) Par.?"
    },
    {
        "text": "dhāryāddhvajāstrapāṇyaṅkamaulibhūṣaṇabhṛnnibhāḥ // (6.2) Par.?"
    },
    {
        "text": "śāliśekharamatvarthamālibhartṛdharā api / (7.1) Par.?"
    },
    {
        "text": "bhojyād bhugandhovrataliṭpāyipāśāśanādayaḥ // (7.2) Par.?"
    },
    {
        "text": "patyuḥ kāntāpriyatamāvadhūpraṇayinīnibhāḥ / (8.1) Par.?"
    },
    {
        "text": "kalatrād vararamaṇapraṇayīśapriyādayaḥ // (8.2) Par.?"
    },
    {
        "text": "sakhyuḥ sakhisamā vāhyādgāmiyānāsanādayaḥ / (9.1) Par.?"
    },
    {
        "text": "jñāteḥ svasṛduhitrātmajāgrajāvarajādayaḥ // (9.2) Par.?"
    },
    {
        "text": "āśrayātsadmaparyāyaśayavāsisadādayaḥ / (10.1) Par.?"
    },
    {
        "text": "vadhyād bhiddveṣijiddhātidhrugripudhvaṃsiśāsanāḥ // (10.2) Par.?"
    },
    {
        "text": "apyantakāridamanadapacchinmathanādayaḥ / (11.1) Par.?"
    },
    {
        "text": "vivakṣito hi saṃbandha ekato 'pi padāttataḥ // (11.2) Par.?"
    },
    {
        "text": "prākpradarśitasaṃbandhiśabdā yojyā yathocitam / (12.1) Par.?"
    },
    {
        "text": "dṛśyate khalu vāhyatve vṛṣasya vṛṣavāhanaḥ // (12.2) Par.?"
    },
    {
        "text": "svatve punarvṛṣapatirdhāryatve vṛṣalāñchanaḥ / (13.1) Par.?"
    },
    {
        "text": "aṃśordhāryatve 'śumālī svatve 'ṃśupatiraśumān // (13.2) Par.?"
    },
    {
        "text": "vadhyatve 'herahiripurbhojyatve cāhibhukśikhī / (14.1) Par.?"
    },
    {
        "text": "cihnairvyaktairbhavedvyakterjātiśabdo 'pi vācakaḥ // (14.2) Par.?"
    },
    {
        "text": "tathāhyagastipūtā digdakṣiṇāśā nigadyate / (15.1) Par.?"
    },
    {
        "text": "ayugviṣamaśabdau tripañcasaptādivācakau // (15.2) Par.?"
    },
    {
        "text": "trinetrapañceṣusaptapalāśādiṣu yojayet / (16.1) Par.?"
    },
    {
        "text": "guṇaśabdo virodhyarthaṃ nañādiritarottaraḥ // (16.2) Par.?"
    },
    {
        "text": "abhidhatte yathā kṛṣṇaḥ syādasitaḥ sitetaraḥ / (17.1) Par.?"
    },
    {
        "text": "vādhyādiṣu pade pūrve vāḍavāgnyādiṣūttare // (17.2) Par.?"
    },
    {
        "text": "dvaye 'pi bhūbhṛdādyeṣu paryāyaparivartanam / (18.1) Par.?"
    },
    {
        "text": "evaṃ parāvṛttisahā yogāḥ syuriti yaugikāḥ // (18.2) Par.?"
    },
    {
        "text": "miśrāḥ punaḥ parāvṛttyasahā gīrvāṇasaṃnibhāḥ / (19.1) Par.?"
    },
    {
        "text": "pravakṣyante 'tra liṅgaṃ tu jñeyaṃ liṅgānuśāsanāt // (19.2) Par.?"
    },
    {
        "text": "devādhidevāḥ prathame kāṇḍe devā dvitīyake / (20.1) Par.?"
    },
    {
        "text": "narastṛtīye tiryañcasturya ekendriyādayaḥ // (20.2) Par.?"
    },
    {
        "text": "ekendriyāḥ pṛthivyambutejovāyumahīruhaḥ / (21.1) Par.?"
    },
    {
        "text": "kṛmipīlakalūtādyāḥ syurdvitricaturindriyāḥ // (21.2) Par.?"
    },
    {
        "text": "pañcendriyāścebhakekimatsyādyāḥ sthalakhāmbugāḥ / (22.1) Par.?"
    },
    {
        "text": "pañcendriyā eva devā narā nairayikā api // (22.2) Par.?"
    },
    {
        "text": "nārakāḥ pañcame sāṅgāḥ ṣaṣṭhe sādhāraṇāḥ sphuṭam / (23.1) Par.?"
    },
    {
        "text": "prastoṣyante 'vyayāścātra tvantāthādī na pūrvagau // (23.2) Par.?"
    },
    {
        "text": "arhañjinaḥ pāragatas trikālavit kṣīṇāṣṭakarmāparameṣṭhyadhīśvaraḥ / (24.1) Par.?"
    },
    {
        "text": "śaṃbhuḥ svayaṃbhūr bhagavāñjagatprabhustīrthaṃkarastīrthakaro jineśvaraḥ // (24.2) Par.?"
    },
    {
        "text": "syādvādyabhayadasārvāḥ sarvajñaḥ sarvadarśikevalinau / (25.1) Par.?"
    },
    {
        "text": "devādhidevabodhadapuruṣottamavītarāgāptāḥ // (25.2) Par.?"
    },
    {
        "text": "etasyāmavasarpiṇyāmṛṣabho 'jitaśaṃbhavau / (26.1) Par.?"
    },
    {
        "text": "abhinandanaḥ sumatistataḥ padmaprabhābhidhaḥ // (26.2) Par.?"
    },
    {
        "text": "supārśvaścandraprabhaśca suvidhiścātha śītalaḥ / (27.1) Par.?"
    },
    {
        "text": "śreyāṃso vāsupūjyaśca vimalo 'nantatīrthakṛt // (27.2) Par.?"
    },
    {
        "text": "dharmaḥ śāntiḥ kuṃthuraro malliśca munisuvrataḥ / (28.1) Par.?"
    },
    {
        "text": "namirnemiḥ pārśvo vīraścaturviṃśatirarhatām // (28.2) Par.?"
    },
    {
        "text": "ṛṣabho vṛṣabhaḥ śreyāñśreyāṃsaḥ syādanantajidanantaḥ / (29.1) Par.?"
    },
    {
        "text": "suvidhistu puṣpadanto munisuvratasuvratau tulyau // (29.2) Par.?"
    },
    {
        "text": "ariṣṭanemistu nemirvīraścaramatīrthakṛt / (30.1) Par.?"
    },
    {
        "text": "mahāvīro vardhamāno devāryo jñātanandanaḥ // (30.2) Par.?"
    },
    {
        "text": "gaṇā navāsyarṣisaṃghā ekādaśa gaṇādhipāḥ / (31.1) Par.?"
    },
    {
        "text": "indrabhūtiragnibhūtivāyubhūtiśca gautamāḥ // (31.2) Par.?"
    },
    {
        "text": "vyaktaḥ sudharmā maṇḍitamauryaputrāvakampitaḥ / (32.1) Par.?"
    },
    {
        "text": "acalabhrātā metāryaḥ prabhāsaśca pṛthakkulāḥ // (32.2) Par.?"
    },
    {
        "text": "kevalī caramo jambūsvāmyatha prabhavatprabhuḥ / (33.1) Par.?"
    },
    {
        "text": "śayyaṃbhavo yaśobhadraḥ saṃbhūtavijayastataḥ // (33.2) Par.?"
    },
    {
        "text": "bhadrabāhuḥ sthūlabhadraḥ śrutakevalino hi ṣaṭ / (34.1) Par.?"
    },
    {
        "text": "mahāgirisuhastyādyā vajrāntā daśapūrviṇaḥ // (34.2) Par.?"
    },
    {
        "text": "ikṣvākukulasambhūtāḥ syāddvāviṃśatir arhatām / (35.1) Par.?"
    },
    {
        "text": "munisuvratanemī tu harivaṃśasamudbhavau // (35.2) Par.?"
    },
    {
        "text": "nābhiśca jitaśatruśca jitāriratha saṃvaraḥ / (36.1) Par.?"
    },
    {
        "text": "megho dharaḥ pratiṣṭhaśca mahāsenanareśvaraḥ // (36.2) Par.?"
    },
    {
        "text": "sugrīvaśca dṛḍharatho viṣṇuśca vasupūjyarāṭ / (37.1) Par.?"
    },
    {
        "text": "kṛtavarmā siṃhaseno bhānuśca viśvasenarāṭ // (37.2) Par.?"
    },
    {
        "text": "sūraḥ sudarśanaḥ kumbhaḥ sumitro vijayastathā / (38.1) Par.?"
    },
    {
        "text": "samudravijayaścāśvasenaḥ siddhārtha eva ca // (38.2) Par.?"
    },
    {
        "text": "marudevā vijayā senā siddhārthā ca maṅgalā / (39.1) Par.?"
    },
    {
        "text": "tataḥ susīmā pṛthvī lakṣmaṇā rāmā tataḥ param // (39.2) Par.?"
    },
    {
        "text": "nandā viṣṇurjayā śyāmā suyaśāḥ suvratācirā / (40.1) Par.?"
    },
    {
        "text": "śrīrdevī prabhāvatī ca padmā vaprā śivā tathā // (40.2) Par.?"
    },
    {
        "text": "vāmā triśalā kramataḥ pitaro mātaro 'rhatām / (41.1) Par.?"
    },
    {
        "text": "syādgomukho mahāyakṣastrimukho yakṣanāyakaḥ // (41.2) Par.?"
    },
    {
        "text": "tumbaruḥ kusumaścāpi mātaṅgo vijayo 'jitaḥ / (42.1) Par.?"
    },
    {
        "text": "brahmā yakṣeṭ kumāraḥ ṣaṇmukhapātālakiṃnarāḥ // (42.2) Par.?"
    },
    {
        "text": "garuḍo gandharvo yakṣeṭ kubero varuṇo 'pi ca / (43.1) Par.?"
    },
    {
        "text": "bhṛkuṭir gomedhaḥ pārśvo mātaṅgo 'rhadupāsakāḥ // (43.2) Par.?"
    },
    {
        "text": "cakreśvaryajitabalā duritāriśca kālikā / (44.1) Par.?"
    },
    {
        "text": "mahākālī śyāmā śāntā bhṛkuṭiśca sutārakā // (44.2) Par.?"
    },
    {
        "text": "aśokā mānavī caṇḍā viditā cāṅkuśā tathā / (45.1) Par.?"
    },
    {
        "text": "kandarpā nirvāṇī balā dhāriṇī dharaṇapriyā // (45.2) Par.?"
    },
    {
        "text": "naradattātha gāndhāryambikā padmāvatī tathā / (46.1) Par.?"
    },
    {
        "text": "siddhāyikā ceti jainyaḥ kramācchāsanadevatāḥ // (46.2) Par.?"
    },
    {
        "text": "vṛṣo gajo 'śvaḥ plavagaḥ krauñco 'bjaṃ svastikaḥ śaśī / (47.1) Par.?"
    },
    {
        "text": "makaraḥ śrīvatsaḥ khaḍgī mahiṣaḥ sūkarastathā // (47.2) Par.?"
    },
    {
        "text": "śyeno vajraṃ mṛgaśchāgo nandyāvarto ghaṭo 'pi ca / (48.1) Par.?"
    },
    {
        "text": "kūrmo nīlotpalaṃ śaṅkhaḥ phaṇī siṃho 'rhatāṃ dhvajāḥ // (48.2) Par.?"
    },
    {
        "text": "raktau ca padmaprabhavāsupūjyau śuklau tu candraprabhapuṣpadantau / (49.1) Par.?"
    },
    {
        "text": "kṛṣṇau punarnemimunī vinīlau śrīmallipārśvau kanakatviṣo 'nye // (49.2) Par.?"
    },
    {
        "text": "utsarpiṇyāmatītāyāṃ caturviṃśatirarhatām / (50.1) Par.?"
    },
    {
        "text": "kevalajñānī nirvāṇī sāgaro 'tha mahāyaśāḥ // (50.2) Par.?"
    },
    {
        "text": "vimalaḥ sarvānubhūtiḥ śrīdharo dattatīrthakṛt / (51.1) Par.?"
    },
    {
        "text": "dāmodaraḥ sutejāśca svāmyatho munisuvrataḥ // (51.2) Par.?"
    },
    {
        "text": "sumatiḥ śivagatiścaivātyāgo 'tha nimīśvaraḥ / (52.1) Par.?"
    },
    {
        "text": "anilo yaśodharākhyaḥ kṛtārtho 'tha jineśvaraḥ // (52.2) Par.?"
    },
    {
        "text": "śuddhamatiḥ śivakaraḥ syandanaścātha saṃpratiḥ / (53.1) Par.?"
    },
    {
        "text": "bhāvinyāṃ tu padmanābhaḥ śūradevaḥ supārśvakaḥ // (53.2) Par.?"
    },
    {
        "text": "svayaṃprabhaśca sarvānubhūtirdevaśrutodayau / (54.1) Par.?"
    },
    {
        "text": "peḍhālaḥ poṭṭilaścāpi śatakīrtiśca suvrataḥ // (54.2) Par.?"
    },
    {
        "text": "amamo niṣkaṣāyaśca niṣpulāko 'tha nirmamaḥ / (55.1) Par.?"
    },
    {
        "text": "citraguptaḥ samādhiśca saṃvaraśca yaśodharaḥ // (55.2) Par.?"
    },
    {
        "text": "vijayo malladevau cānantavīryaśca bhadrakṛt / (56.1) Par.?"
    },
    {
        "text": "evaṃ sarvāvasarpiṇyutsarpiṇīṣu jinottamāḥ // (56.2) Par.?"
    },
    {
        "text": "teṣāṃ ca deho 'dbhutarūpagandho nirāmayaḥ svedamalojjhitaśca / (57.1) Par.?"
    },
    {
        "text": "śvāso 'bjagandho rudhirāmiṣaṃ tu gokṣīradhārādhavalaṃ hyavisram // (57.2) Par.?"
    },
    {
        "text": "āhāranīhāravidhistvadṛśyaścatvāra ete 'tiśayāḥ sahotthāḥ / (58.1) Par.?"
    },
    {
        "text": "kṣetre sthitiryojanamātrake 'pi nṛdevatiryagjanakoṭikoṭeḥ // (58.2) Par.?"
    },
    {
        "text": "vāṇī nṛtiryaksuralokabhāṣāsaṃvādinī yojanagāminī ca / (59.1) Par.?"
    },
    {
        "text": "bhāmaṇḍalaṃ cāru ca maulipṛṣṭhe viḍambitāharpatimaṇḍalaśrīḥ // (59.2) Par.?"
    },
    {
        "text": "sāgre ca gavyūtiśatadvaye rujāvairetayo māryativṛṣṭyavṛṣṭayaḥ / (60.1) Par.?"
    },
    {
        "text": "durbhikṣamanyasvakacakrato bhayaṃ syānnaita ekādaśa karmaghātajāḥ // (60.2) Par.?"
    },
    {
        "text": "khe dharmacakraṃ camarāḥ sapādapīṭhaṃ mṛgendrāsanamujjvalaṃ ca / (61.1) Par.?"
    },
    {
        "text": "chattratrayaṃ ratnamayadhvajo 'ṅghrinyāse ca cāmīkarapaṅkajāni // (61.2) Par.?"
    },
    {
        "text": "vapratrayaṃ cāru caturmukhāṅgatāś caityadrumo 'dhovadanāśca kaṇṭakāḥ / (62.1) Par.?"
    },
    {
        "text": "drumānatirdundubhināda uccakairvāto 'nukūlaḥ śakunāḥ pradakṣiṇāḥ // (62.2) Par.?"
    },
    {
        "text": "gandhāmbuvarṣaṃ bahuvarṇapuṣpavṛṣṭiḥ kacaśmaśrunakhāpravṛddhiḥ / (63.1) Par.?"
    },
    {
        "text": "caturvidhā martyanikāyakoṭijaghanyabhāvādapi pārśvadeśe // (63.2) Par.?"
    },
    {
        "text": "kratūnāmindriyārthānāmanukūlatvamityamī / (64.1) Par.?"
    },
    {
        "text": "ekonaviṃśatidaivyāścatustriṃśacca mīlitāḥ // (64.2) Par.?"
    },
    {
        "text": "saṃskāravattvamaudāryamupacāraparītatā / (65.1) Par.?"
    },
    {
        "text": "meghanirghoṣagāmbhīryaṃ pratinādavidhāyitā // (65.2) Par.?"
    },
    {
        "text": "dakṣiṇatvamupanītarāgatvaṃ ca mahārthatā / (66.1) Par.?"
    },
    {
        "text": "avyāhatatvaṃ śiṣṭatvaṃ saṃśayānāmasaṃbhavaḥ // (66.2) Par.?"
    },
    {
        "text": "nirākṛtānyottaratvaṃ hṛdayaṃgamitāpi ca / (67.1) Par.?"
    },
    {
        "text": "mithaḥ sākāṅkṣatā prastāvaucityaṃ tattvaniṣṭhatā // (67.2) Par.?"
    },
    {
        "text": "aprakīrṇaprasṛtatvam asvaślāghānyaninditā / (68.1) Par.?"
    },
    {
        "text": "ābhijātyamatisnigdhamadhuratvaṃ praśasyatā // (68.2) Par.?"
    },
    {
        "text": "amarmavedhitaudāryaṃ dharmārthapratibaddhatā / (69.1) Par.?"
    },
    {
        "text": "kārakādyaviparyāso vibhramādiviyuktatā // (69.2) Par.?"
    },
    {
        "text": "citrakṛttvam adbhutatvaṃ tathānativilambitā / (70.1) Par.?"
    },
    {
        "text": "anekajātivaicitryam āropitaviśeṣitā // (70.2) Par.?"
    },
    {
        "text": "sattvapradhānatā varṇapadavākyaviviktatā / (71.1) Par.?"
    },
    {
        "text": "avyucchittir akheditvaṃ pañcatriṃśacca vāgguṇāḥ // (71.2) Par.?"
    },
    {
        "text": "antarāyā dānalābhavīryabhogopabhogagāḥ / (72.1) Par.?"
    },
    {
        "text": "hāso ratyaratī bhītirjugupsā śoka eva ca // (72.2) Par.?"
    },
    {
        "text": "kāmo mithyātvamajñānaṃ nidrā cāviratistathā / (73.1) Par.?"
    },
    {
        "text": "rogo dveṣaśca no doṣāsteṣāmaṣṭādaśāpyamī // (73.2) Par.?"
    },
    {
        "text": "mahānando 'mṛtaṃ siddhiḥ kaivalyamapunarbhavaḥ / (74.1) Par.?"
    },
    {
        "text": "śivaṃ niḥśreyasaṃ śreyo nirvāṇaṃ brahma nirvṛtiḥ // (74.2) Par.?"
    },
    {
        "text": "mahodayaḥ sarvaduḥkhakṣayo niryāṇamakṣaram / (75.1) Par.?"
    },
    {
        "text": "muktirmokṣo 'pavargo 'tha mumukṣuḥ śramaṇo yatiḥ // (75.2) Par.?"
    },
    {
